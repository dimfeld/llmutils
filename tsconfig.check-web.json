{
  "extends": "./tsconfig.json",
  "include": [
    ".svelte-kit/ambient.d.ts",
    ".svelte-kit/non-ambient.d.ts",
    ".svelte-kit/types/**/$types.d.ts",
    "build.ts",
    "src/**/*.ts",
    "src/**/*.js",
    "test/**/*.ts",
    "test/**/*.js",
    "scripts/**/*.ts",
    "vite.config.ts",
    "test-preload.ts",
    "svelte.config.js",
    "eslint.config.js"
  ],
  "exclude": [
    "**/*.test.ts",
    "vite.config.ts",
    "src/service-worker.js",
    "src/service-worker/**/*.js",
    "src/service-worker.ts",
    "src/service-worker/**/*.ts",
    "src/service-worker.d.ts",
    "src/service-worker/**/*.d.ts"
  ]
}
