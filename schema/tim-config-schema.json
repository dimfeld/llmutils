{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "githubUsername": {
      "description": "GitHub username for PR filtering",
      "type": "string"
    },
    "branchPrefix": {
      "type": "string",
      "maxLength": 20,
      "description": "Prefix to prepend to auto-generated branch names (for example \"di/\")"
    },
    "requireBranchPrefix": {
      "description": "If true, commands that create branches will fail unless a branchPrefix is configured (via repo config or project setting).",
      "type": "boolean"
    },
    "artifactRetentionDays": {
      "description": "Number of days to retain purge-eligible plan artifacts",
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "sync": {
      "description": "Machine-local sync configuration for multi-node tim replication",
      "type": "object",
      "properties": {
        "role": {
          "type": "string",
          "enum": [
            "main",
            "persistent",
            "ephemeral"
          ]
        },
        "nodeId": {
          "type": "string"
        },
        "mainUrl": {
          "type": "string"
        },
        "nodeToken": {
          "type": "string"
        },
        "nodeTokenEnv": {
          "type": "string"
        },
        "allowedNodes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "nodeId": {
                "type": "string"
              },
              "label": {
                "type": "string"
              },
              "tokenHash": {
                "type": "string",
                "pattern": "^[a-fA-F0-9]{64}$"
              },
              "tokenEnv": {
                "type": "string"
              }
            },
            "required": [
              "nodeId"
            ],
            "additionalProperties": false
          }
        },
        "serverPort": {
          "type": "integer",
          "minimum": 0,
          "maximum": 65535
        },
        "serverHost": {
          "type": "string"
        },
        "requireSecureTransport": {
          "type": "boolean"
        },
        "disabled": {
          "type": "boolean"
        },
        "offline": {
          "type": "boolean"
        },
        "pollIntervalSeconds": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "sequenceRetentionDays": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      },
      "additionalProperties": false
    },
    "slack": {
      "description": "Machine-local Slack workspace configuration for outbound notifications",
      "type": "object",
      "properties": {
        "workspaces": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "object",
            "properties": {
              "token": {
                "type": "string"
              },
              "dailyDigest": {
                "type": "object",
                "properties": {
                  "time": {
                    "type": "string",
                    "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$"
                  },
                  "timezone": {
                    "type": "string"
                  },
                  "staleAfterHours": {
                    "type": "number",
                    "exclusiveMinimum": 0
                  },
                  "weekdays": {
                    "minItems": 1,
                    "type": "array",
                    "items": {
                      "type": "string",
                      "enum": [
                        "sunday",
                        "monday",
                        "tuesday",
                        "wednesday",
                        "thursday",
                        "friday",
                        "saturday"
                      ]
                    }
                  },
                  "reviewGroups": {
                    "minItems": 1,
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "name": {
                          "type": "string",
                          "minLength": 1
                        },
                        "label": {
                          "type": "string",
                          "minLength": 1
                        }
                      },
                      "required": [
                        "name",
                        "label"
                      ],
                      "additionalProperties": false
                    }
                  },
                  "defaultGroupName": {
                    "type": "string",
                    "minLength": 1
                  },
                  "linearMilestones": {
                    "type": "object",
                    "properties": {
                      "enabled": {
                        "type": "boolean"
                      },
                      "apiKeyEnv": {
                        "type": "string",
                        "minLength": 1
                      }
                    },
                    "additionalProperties": false
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "environment": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "pattern": "^[A-Z_][A-Z0-9_]*$"
      },
      "additionalProperties": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "object",
            "properties": {
              "value": {
                "type": "string"
              },
              "precedence": {
                "type": "string",
                "enum": [
                  "override-dotenv"
                ]
              }
            },
            "required": [
              "value"
            ],
            "additionalProperties": false
          }
        ]
      },
      "description": "Project-level environment variables rendered at process launch time"
    },
    "issueTracker": {
      "description": "Issue tracking service to use for import commands and issue-related operations",
      "type": "string",
      "enum": [
        "github",
        "linear"
      ]
    },
    "postApplyCommands": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "command": {
            "type": "string"
          },
          "workingDirectory": {
            "type": "string"
          },
          "env": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {
              "type": "string"
            }
          },
          "allowFailure": {
            "default": false,
            "type": "boolean"
          },
          "hideOutputOnSuccess": {
            "default": false,
            "type": "boolean"
          }
        },
        "required": [
          "title",
          "command"
        ]
      }
    },
    "notifications": {
      "description": "Configuration for notification hooks when agent/review commands finish",
      "type": "object",
      "properties": {
        "command": {
          "type": "string"
        },
        "workingDirectory": {
          "type": "string"
        },
        "env": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        "enabled": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "lifecycle": {
      "description": "Lifecycle commands to run before and after tim command execution",
      "type": "object",
      "properties": {
        "commands": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": {
                "type": "string"
              },
              "command": {
                "type": "string"
              },
              "mode": {
                "description": "Whether to run the command and wait for it to finish or run it in the background.",
                "type": "string",
                "enum": [
                  "run",
                  "daemon"
                ]
              },
              "check": {
                "description": "Command to check if a daemon mode lifecycle command has finished initializting",
                "type": "string"
              },
              "shutdown": {
                "description": "Command to shutdown a daemon mode lifecycle command",
                "type": "string"
              },
              "workingDirectory": {
                "type": "string"
              },
              "env": {
                "type": "object",
                "propertyNames": {
                  "type": "string"
                },
                "additionalProperties": {
                  "type": "string"
                }
              },
              "allowFailure": {
                "type": "boolean"
              },
              "onlyWorkspaceType": {
                "type": "string",
                "enum": [
                  "auto",
                  "standard",
                  "primary"
                ]
              },
              "runIn": {
                "description": "Optional list of command contexts in which this lifecycle command should run. Omit to run in all contexts.",
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "agent",
                    "review",
                    "proof"
                  ]
                }
              }
            },
            "required": [
              "title",
              "command"
            ]
          }
        }
      }
    },
    "subprocessMonitor": {
      "description": "Opt-in timeout rules for subprocesses spawned by agent executors",
      "type": "object",
      "properties": {
        "pollIntervalSeconds": {
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "rules": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "match": {
                "anyOf": [
                  {
                    "anyOf": [
                      {
                        "type": "string",
                        "minLength": 1
                      },
                      {
                        "type": "object",
                        "properties": {
                          "regex": {
                            "type": "string",
                            "minLength": 1
                          },
                          "flags": {
                            "type": "string"
                          }
                        },
                        "required": [
                          "regex"
                        ],
                        "additionalProperties": false
                      }
                    ]
                  },
                  {
                    "minItems": 1,
                    "type": "array",
                    "items": {
                      "anyOf": [
                        {
                          "type": "string",
                          "minLength": 1
                        },
                        {
                          "type": "object",
                          "properties": {
                            "regex": {
                              "type": "string",
                              "minLength": 1
                            },
                            "flags": {
                              "type": "string"
                            }
                          },
                          "required": [
                            "regex"
                          ],
                          "additionalProperties": false
                        }
                      ]
                    }
                  }
                ]
              },
              "timeoutSeconds": {
                "type": "integer",
                "exclusiveMinimum": 0,
                "maximum": 9007199254740991
              },
              "description": {
                "type": "string"
              }
            },
            "required": [
              "match",
              "timeoutSeconds"
            ],
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "headless": {
      "description": "Configuration for headless output streaming",
      "type": "object",
      "properties": {
        "url": {
          "description": "WebSocket URL for headless output streaming",
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "paths": {
      "type": "object",
      "properties": {
        "docs": {
          "description": "Paths to directories to search for .md and .mdc documentation files to auto-include",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "trackingFile": {
          "description": "Path to workspace tracking file (default: ~/.config/tim/workspaces.json)",
          "type": "string"
        }
      }
    },
    "assignments": {
      "type": "object",
      "properties": {
        "staleTimeout": {
          "description": "Number of days after which plan assignments are considered stale",
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        }
      }
    },
    "planAutocompleteStatus": {
      "description": "Target status for automatic plan completion transitions",
      "type": "string",
      "enum": [
        "needs_review",
        "done"
      ]
    },
    "tags": {
      "description": "Configuration for plan tags, including allowlists",
      "type": "object",
      "properties": {
        "allowed": {
          "description": "List of allowed tags. If set, only these tags can be added to plans.",
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "autoexamples": {
      "type": "array",
      "items": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "object",
            "properties": {
              "find": {
                "type": "string",
                "description": "String to search for in the prompt to trigger this example."
              },
              "example": {
                "type": "string",
                "description": "Example string to pass as --example argument when find matches."
              }
            },
            "required": [
              "find",
              "example"
            ]
          }
        ]
      }
    },
    "models": {
      "type": "object",
      "properties": {
        "execution": {
          "description": "Model spec for tim run model",
          "type": "string"
        },
        "answerPr": {
          "description": "Model spec for tim answer-pr model",
          "type": "string"
        },
        "convert_yaml": {
          "description": "Model spec for tim markdown-to-yaml extraction",
          "type": "string"
        },
        "stepGeneration": {
          "description": "Model spec for tim prepare phase generation",
          "type": "string"
        }
      }
    },
    "answerPr": {
      "type": "object",
      "properties": {
        "mode": {
          "description": "Default mode for answer-pr command",
          "type": "string",
          "enum": [
            "hybrid",
            "inline",
            "separate"
          ]
        },
        "comment": {
          "description": "Default value for whether to add comments after processing",
          "type": "boolean"
        },
        "commit": {
          "description": "Default value for whether to commit changes after processing",
          "type": "boolean"
        }
      }
    },
    "prCreation": {
      "description": "Configuration for PR creation behavior",
      "type": "object",
      "properties": {
        "draft": {
          "description": "Whether PRs should be created as drafts by default",
          "type": "boolean"
        },
        "titlePrefix": {
          "description": "Prefix to add to PR titles when creating PRs",
          "type": "string"
        },
        "autoCreatePr": {
          "description": "Automatically create a PR when agent completes. Values: never, done, needs_review, always",
          "type": "string",
          "enum": [
            "never",
            "done",
            "needs_review",
            "always"
          ]
        }
      },
      "additionalProperties": false
    },
    "prFix": {
      "description": "Configuration for the pr fix command",
      "type": "object",
      "properties": {
        "executor": {
          "description": "Executor to use for PR review thread fixes",
          "type": "string",
          "enum": [
            "claude-code",
            "codex-cli"
          ]
        },
        "model": {
          "description": "Model to use for PR review thread fixes",
          "type": "string"
        },
        "effort": {
          "description": "Reasoning effort to use for PR review thread fixes",
          "anyOf": [
            {
              "type": "string",
              "enum": [
                "low",
                "medium",
                "high",
                "xhigh",
                "max"
              ]
            },
            {
              "type": "string",
              "enum": [
                "low",
                "medium",
                "high",
                "xhigh"
              ]
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "developmentWorkflow": {
      "description": "Development workflow type, affects UI button visibility",
      "type": "string",
      "enum": [
        "pr-based",
        "trunk-based"
      ]
    },
    "generate": {
      "description": "Configuration for tim generate defaults",
      "type": "object",
      "properties": {
        "defaultExecutor": {
          "description": "Default executor to use for the generate command",
          "type": "string",
          "enum": [
            "claude-code",
            "codex-cli"
          ]
        }
      },
      "additionalProperties": false
    },
    "modelApiKeys": {
      "description": "Map of model ID or prefix to environment variable name for API key. Example: {\"openai/\": \"MY_OPENAI_KEY\", \"anthropic/claude-3.5-sonnet\": \"CLAUDE_SONNET_KEY\"}",
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "string",
        "description": "Environment variable name to use for API key"
      }
    },
    "defaultExecutor": {
      "description": "Default executor to use for plan execution",
      "type": "string"
    },
    "defaultOrchestrator": {
      "description": "Default orchestrator to use for the agent command main loop",
      "type": "string"
    },
    "orchestrator": {
      "description": "Model and effort overrides for the agent command main loop orchestrator",
      "type": "object",
      "properties": {
        "model": {
          "type": "object",
          "properties": {
            "claude": {
              "description": "Model override for claude-code orchestrator",
              "type": "string"
            },
            "codex": {
              "description": "Model override for codex-cli orchestrator",
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "effort": {
          "type": "object",
          "properties": {
            "claude": {
              "description": "Reasoning effort override for claude-code orchestrator",
              "type": "string",
              "enum": [
                "low",
                "medium",
                "high",
                "xhigh",
                "max"
              ]
            },
            "codex": {
              "description": "Reasoning effort override for codex-cli orchestrator",
              "type": "string",
              "enum": [
                "low",
                "medium",
                "high",
                "xhigh"
              ]
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "terminalInput": {
      "description": "Whether terminal input is enabled during Claude Code execution in tim agent",
      "type": "boolean"
    },
    "terminalApp": {
      "description": "Terminal application to use when opening new terminal windows (for example \"WezTerm\", \"Terminal\", or \"iTerm\"). Defaults to \"WezTerm\".",
      "type": "string"
    },
    "defaultSubagentExecutor": {
      "description": "Default executor to use for subagents in the agent command (codex-cli, claude-code, or dynamic)",
      "type": "string",
      "enum": [
        "codex-cli",
        "claude-code",
        "dynamic"
      ]
    },
    "dynamicSubagentInstructions": {
      "description": "Instructions for the orchestrator when choosing between claude-code and codex-cli for subagent execution in dynamic mode",
      "type": "string"
    },
    "subagents": {
      "description": "Per-subagent model overrides keyed by executor (claude, codex)",
      "type": "object",
      "properties": {
        "implementer": {
          "type": "object",
          "properties": {
            "model": {
              "type": "object",
              "properties": {
                "claude": {
                  "description": "Model override for claude-code execution",
                  "type": "string"
                },
                "codex": {
                  "description": "Model override for codex-cli execution",
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "tester": {
          "type": "object",
          "properties": {
            "model": {
              "type": "object",
              "properties": {
                "claude": {
                  "description": "Model override for claude-code execution",
                  "type": "string"
                },
                "codex": {
                  "description": "Model override for codex-cli execution",
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "tddTests": {
          "type": "object",
          "properties": {
            "model": {
              "type": "object",
              "properties": {
                "claude": {
                  "description": "Model override for claude-code execution",
                  "type": "string"
                },
                "codex": {
                  "description": "Model override for codex-cli execution",
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "verifier": {
          "type": "object",
          "properties": {
            "model": {
              "type": "object",
              "properties": {
                "claude": {
                  "description": "Model override for claude-code execution",
                  "type": "string"
                },
                "codex": {
                  "description": "Model override for codex-cli execution",
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "reviewer": {
          "type": "object",
          "properties": {
            "model": {
              "type": "object",
              "properties": {
                "claude": {
                  "description": "Model override for claude-code execution",
                  "type": "string"
                },
                "codex": {
                  "description": "Model override for codex-cli execution",
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "workspaceCreation": {
      "type": "object",
      "properties": {
        "cloneMethod": {
          "type": "string",
          "enum": [
            "git",
            "cp",
            "mac-cow"
          ]
        },
        "repositoryUrl": {
          "type": "string"
        },
        "sourceDirectory": {
          "type": "string"
        },
        "cloneLocation": {
          "type": "string"
        },
        "postCloneCommands": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": {
                "type": "string"
              },
              "command": {
                "type": "string"
              },
              "workingDirectory": {
                "type": "string"
              },
              "env": {
                "type": "object",
                "propertyNames": {
                  "type": "string"
                },
                "additionalProperties": {
                  "type": "string"
                }
              },
              "allowFailure": {
                "default": false,
                "type": "boolean"
              },
              "hideOutputOnSuccess": {
                "default": false,
                "type": "boolean"
              }
            },
            "required": [
              "title",
              "command"
            ]
          }
        },
        "workspaceUpdateCommands": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": {
                "type": "string"
              },
              "command": {
                "type": "string"
              },
              "workingDirectory": {
                "type": "string"
              },
              "env": {
                "type": "object",
                "propertyNames": {
                  "type": "string"
                },
                "additionalProperties": {
                  "type": "string"
                }
              },
              "allowFailure": {
                "default": false,
                "type": "boolean"
              },
              "hideOutputOnSuccess": {
                "default": false,
                "type": "boolean"
              }
            },
            "required": [
              "title",
              "command"
            ]
          }
        },
        "createBranch": {
          "type": "boolean"
        },
        "copyAdditionalGlobs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "requireAutoType": {
          "type": "boolean"
        }
      }
    },
    "planning": {
      "type": "object",
      "properties": {
        "direct_mode": {
          "description": "Default behavior for direct mode in generate and prepare commands",
          "type": "boolean"
        },
        "claude_mode": {
          "description": "Default behavior for Claude mode in generate and prepare commands",
          "type": "boolean"
        },
        "instructions": {
          "description": "Path to a planning document file to include in all planning prompts",
          "type": "string"
        }
      }
    },
    "compaction": {
      "type": "object",
      "properties": {
        "defaultExecutor": {
          "description": "Default executor to use when compacting plans",
          "type": "string"
        },
        "defaultModel": {
          "description": "Default model identifier to use for compaction prompts",
          "type": "string"
        },
        "minimumAgeDays": {
          "description": "Minimum age in days before a plan becomes eligible for compaction",
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "sections": {
          "type": "object",
          "properties": {
            "details": {
              "description": "Whether the details section should be compacted",
              "type": "boolean"
            },
            "research": {
              "description": "Whether the research section should be compacted",
              "type": "boolean"
            }
          }
        }
      }
    },
    "agents": {
      "description": "Custom instructions for implementer, tester, tdd-tests, and reviewer agents",
      "type": "object",
      "properties": {
        "implementer": {
          "type": "object",
          "properties": {
            "instructions": {
