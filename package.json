{
  "name": "llmutils",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "bin": {
    "tim": "./src/tim/tim.ts"
  },
  "scripts": {
    "check": "tsc --noEmit -p tsconfig.build.json",
    "check-web": "svelte-kit sync && bun run --bun svelte-check --tsconfig ./tsconfig.check-web.json",
    "check-web:watch": "svelte-kit sync && bun run --bun svelte-check --tsconfig ./tsconfig.check-web.json --watch",
    "dev": "bun --bun vite dev",
    "build": "./build.ts",
    "build-web": "bun --bun vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "lint": "echo 'lint disabled for now'",
    "dev-install": "bun run build && pnpm add -g file://$(pwd)",
    "format": "prettier --write --log-level warn .",
    "update-schemas": "scripts/update-json-schemas.ts",
    "test": "bun run test-cli && bun run test-web",
    "test-web": "bun --bun vitest run",
    "test-cli": "bun test",
    "tim": "src/tim/tim.ts"
  },
  "devDependencies": {
