{
  "name": "llmutils",
  "private": true,
  "bin": {
    "tim": "./src/tim/tim.ts"
  },
  "type": "module",
  "module": "src/index.ts",
  "scripts": {
    "check": "tsc --noEmit -p tsconfig.build.json",
    "check-web": "svelte-kit sync && bun run --bun svelte-check --incremental --tsgo --tsconfig ./tsconfig.check-web.json",
    "check-web:watch": "svelte-kit sync && bun run --bun svelte-check --incremental --tsgo --tsconfig ./tsconfig.check-web.json --watch",
    "dev": "bun --bun vite dev",
    "build": "./build.ts",
    "build-web": "bun --bun vite build",
    "build-all": "bun run dev-install && bun run build-web",
    "preview": "bun --bun vite preview",
    "web-prod": "bun run build-web && PORT=8124 bun build/index.js",
    "prepare": "svelte-kit sync || echo ''",
    "lint": "oxlint",
    "dev-install": "bun run build && pnpm add -g file://$(pwd)",
    "format": "oxfmt --write .",
    "update-schemas": "scripts/update-json-schemas.ts",
    "test": "bun --bun vitest run --project server",
    "test:client": "bun --bun vitest run --project client",
    "tim": "src/tim/tim.ts",
    "webhook-receiver": "bun run src/webhooks/server.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.2.12",
    "@ai-sdk/cerebras": "^0.2.16",
    "@ai-sdk/google": "^1.2.22",
