    "@openrouter/ai-sdk-provider": "^0.7.5",
    "@pierre/diffs": "1.2.5",
    "ai": "^4.3.19",
    "ajv": "^8.20.0",
    "chalk": "^5.6.2",
    "change-case": "^5.4.4",
    "clipboardy": "^5.3.1",
    "commander": "^14.0.3",
    "diff": "^8.0.4",
    "dotenv": "^16.6.1",
    "fast-glob": "^3.3.3",
    "fastmcp": "^3.34.0",
    "find-up": "^8.0.0",
